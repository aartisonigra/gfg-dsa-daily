Given an array arr[] and an integer k, the task is to find the length of longest subarray in which the count of elements greater than k is more than the count of elements less than or equal to k.

Examples:

Input: arr[] = [1, 2, 3, 4, 1], k = 2
Output: 3
Explanation: The subarray [2, 3, 4] or [3, 4, 1] satisfy the given condition, and there is no subarray of length 4 or 5 which will hold the given condition, so the answer is 3.
Input: arr[] = [6, 5, 3, 4], k = 2
Output: 4
Explanation: In the subarray [6, 5, 3, 4], there are 4 elements > 2 and 0 elements <= 2, so it is the longest subarray.

  SOLUTIONS:

class Solution {
    longestSubarray(arr, k) {
        let n = arr.length;
        
        // Step 1: Convert array
        for (let i = 0; i < n; i++) {
            if (arr[i] > k) {
                arr[i] = 1;
            } else {
                arr[i] = -1;
            }
        }
        
        let prefixSum = 0;
        let maxLen = 0;
        let map = new Map();
        
        for (let i = 0; i < n; i++) {
            prefixSum += arr[i];
            
            // If total sum positive
            if (prefixSum > 0) {
                maxLen = i + 1;
            }
            
            // If prefixSum not seen before, store index
            if (!map.has(prefixSum)) {
                map.set(prefixSum, i);
            }
            
            // Check if (prefixSum - 1) exists
            if (map.has(prefixSum - 1)) {
                let length = i - map.get(prefixSum - 1);
                maxLen = Math.max(maxLen, length);
            }
        }
        
        return maxLen;
    }
}
